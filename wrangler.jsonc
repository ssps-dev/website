{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ssps-hq-website",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-03-16",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      // Self-reference service binding used for caching — service name must match the worker name above
      // See https://opennext.js.org/cloudflare/caching
      "binding": "WORKER_SELF_REFERENCE",
      "service": "ssps-hq-website"
    }
  ],
  "r2_buckets": [
    {
      // R2 bucket for Next.js incremental cache (ISR / fetch cache)
      // Create it before deploying: npx wrangler r2 bucket create ssps-hq-website-opennext-cache
      // See https://opennext.js.org/cloudflare/caching
      "binding": "NEXT_INC_CACHE_R2_BUCKET",
      "bucket_name": "ssps-hq-website-opennext-cache"
    }
  ],
  "images": {
    // Enables Cloudflare's built-in image optimization
    // See https://opennext.js.org/cloudflare/howtos/image
    "binding": "IMAGES"
  }
} 
